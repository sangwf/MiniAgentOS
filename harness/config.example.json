{
  "agent_command": [
    "../bin/qemu-system-aarch64-local",
    "-machine",
    "virt",
    "-cpu",
    "cortex-a53",
    "-nographic",
    "-kernel",
    "target/aarch64-virt/debug/minios",
    "-global",
    "virtio-mmio.force-legacy=on",
    "-device",
    "virtio-net-device,netdev=net0",
    "-netdev",
    "user,id=net0"
  ],
  "path_prefixes": [
    "/opt/homebrew/bin",
    "$HOME/homebrew/bin",
    "$HOME/.cargo/bin",
    "$HOME/.miniagentos/qemu-bottle/qemu/10.2.1/bin"
  ],
  "workdir": "runtime",
  "prompt": "Goal >",
  "boot_timeout_sec": 30,
  "case_timeout_sec": 90,
  "result_sink": {
    "bind_host": "127.0.0.1",
    "agent_host": "10.0.2.2",
    "port": 0,
    "path": "/result"
  },
  "source_fixture": {
    "bind_host": "127.0.0.1",
    "agent_host": "10.0.2.2",
    "port": 0,
    "path": "/source"
  },
  "model_fixture": {
    "bind_host": "127.0.0.1",
    "agent_host": "10.0.2.2",
    "port": 0,
    "path": "/summarize",
    "error_path": "/summarize-error"
  },
  "interpretation_fixture": {
    "bind_host": "127.0.0.1",
    "agent_host": "10.0.2.2",
    "port": 0,
    "path": "/interpret",
    "error_path": "/interpret-error"
  },
  "x_fixture": {
    "bind_host": "127.0.0.1",
    "agent_host": "10.0.2.2",
    "port": 0,
    "post_path": "/x/post_tweet",
    "search_path": "/x/search/recent",
    "user_posts_path": "/x/user_posts"
  }
}
