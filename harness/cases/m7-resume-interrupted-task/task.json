{
  "goal_id": "m7-resume-interrupted-task",
  "goal": "Save a bounded checkpoint and resume from it truthfully in a later turn.",
  "turns": [
    {
      "input_mode": "text_line",
      "input_payload": "Save a checkpoint after remembering the provider."
    },
    {
      "input_mode": "text_line",
      "input_payload": "Resume from the saved checkpoint and tell me the remembered fact."
    }
  ],
  "fixture": {
    "source_asset": "source.md"
  },
  "expect": {
    "boot_prompt": "Goal >",
    "timeout_sec": 30,
    "result_required": false,
    "required_trace_events": [
      "session_started",
      "user_turn_received",
      "model_turn_started",
      "tool_call_requested",
      "tool_call_completed",
      "assistant_response_rendered",
      "loop_stopped",
      "goal_completed"
    ],
    "session_transcript_required": true,
    "expected_turn_count": 2,
    "terminal_result_required": true,
    "terminal_fields": [
      "status",
      "summary"
    ],
    "terminal_status": "ok",
    "terminal_summary_must_include": [
      "Brave Search"
    ],
    "expected_tool_calls": [
      {
        "event": "tool_call_requested",
        "tool": "save_checkpoint"
      },
      {
        "event": "tool_call_requested",
        "tool": "resume_checkpoint"
      },
      {
        "event": "tool_call_requested",
        "tool": "read_memory"
      }
    ],
    "max_tool_calls": 3,
    "memory_snapshot_required": true,
    "memory_entry_count": 3,
    "expected_memory_entries": [
      {
        "kind": "task"
      },
      {
        "id": "mem-source-checkpoint",
        "kind": "source"
      },
      {
        "kind": "conversation"
      }
    ],
    "memory_events_required": true,
    "expected_memory_events": [
      {
        "event": "checkpoint_saved"
      },
      {
        "event": "checkpoint_resumed"
      }
    ],
    "context_snapshot_required": true,
    "context_turn_count": 2,
    "required_context_sections": [
      "Current request",
      "Known sources",
      "Recent conversation"
    ],
    "context_budget_required": true,
    "context_budget_turn_count": 2,
    "checkpoint_required": true,
    "checkpoint_count": 1,
    "expected_checkpoints": [
      {
        "label": "remembered-provider"
      }
    ]
  }
}
