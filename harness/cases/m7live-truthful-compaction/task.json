{
  "goal_id": "m7live-truthful-compaction",
  "goal": "Validate live guest-side truthful compaction after a long fetch result.",
  "requires_guest_openai": true,
  "input_mode": "text_line",
  "input_payload": "Fetch {{SOURCE_URL}}, then inspect mem-source with read_memory and tell me whether the retained source memory is compacted and what exact contingency code it kept.",
  "fixture": {
    "source_asset": "source.md"
  },
  "expect": {
    "boot_prompt": "Goal >",
    "timeout_sec": 120,
    "result_required": false,
    "required_trace_events": [
      "session_started",
      "user_turn_received",
      "model_turn_started",
      "tool_call_requested",
      "tool_call_completed",
      "assistant_response_rendered",
      "loop_stopped",
      "goal_completed"
    ],
    "session_transcript_required": true,
    "expected_turn_count": 1,
    "terminal_result_required": true,
    "terminal_fields": [
      "status",
      "summary"
    ],
    "terminal_status": "ok",
    "terminal_summary_must_include": [
      "ORBIT-42",
      "compacted"
    ],
    "expected_tool_calls": [
      {
        "event": "tool_call_requested",
        "tool": "fetch_url"
      },
      {
        "event": "tool_call_requested",
        "tool": "read_memory"
      }
    ],
    "max_tool_calls": 4,
    "memory_snapshot_required": true,
    "expected_memory_entries": [
      {
        "id": "mem-source",
        "kind": "source",
        "state": "compacted"
      }
    ],
    "memory_events_required": true,
    "expected_memory_events": [
      {
        "event": "memory_compacted",
        "entry_id": "mem-source",
        "to_state": "compacted"
      }
    ],
    "context_snapshot_required": true,
    "context_turn_count": 3,
    "required_context_sections": [
      "Current request",
      "Latest tool result",
      "Working memory",
      "Known sources",
      "Workspace memory",
      "Session state",
      "Recent conversation"
    ],
    "context_budget_required": true,
    "context_budget_turn_count": 3,
    "required_context_budget_fields": [
      "instructions_chars",
      "current_request_chars",
      "latest_tool_result_chars",
      "working_memory_chars",
      "known_sources_chars",
      "workspace_memory_chars",
      "session_state_chars",
      "recent_conversation_chars",
      "estimated_total_tokens"
    ]
  }
}
