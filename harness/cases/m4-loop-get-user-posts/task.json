{
  "goal_id": "m4-loop-get-user-posts",
  "goal": "Exercise the M4 loop with a get_user_posts tool call and session-state write.",
  "input_mode": "text_line",
  "input_payload": "What did karpathy post recently?",
  "fixture": {
    "source_asset": "source.md",
    "x_asset": "x.json"
  },
  "expect": {
    "boot_prompt": "Goal >",
    "timeout_sec": 30,
    "required_trace_events": [
      "session_started",
      "user_turn_received",
      "model_turn_started",
      "model_turn_completed",
      "tool_call_requested",
      "tool_call_started",
      "tool_call_completed",
      "assistant_response_rendered",
      "loop_stopped"
    ],
    "session_transcript_required": true,
    "expected_turn_count": 1,
    "max_tool_calls": 2,
    "expected_tool_calls": [
      {
        "event": "tool_call_requested",
        "tool": "get_user_posts",
        "arguments": {
          "username": "karpathy"
        }
      },
      {
        "event": "tool_call_requested",
        "tool": "write_session_state",
        "arguments": {
          "key": "last_posts"
        }
      }
    ],
    "result_required": false,
    "terminal_result_required": true,
    "terminal_fields": [
      "status",
      "summary"
    ],
    "terminal_status": "ok",
    "terminal_summary_must_include": [
      "@karpathy"
    ],
    "request_counts": {
      "x_post_requests": 0,
      "x_search_requests": 0,
      "x_user_posts_requests": 1
    }
  }
}
