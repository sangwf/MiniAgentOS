{
  "goal_id": "m3-nl-policy-refusal",
  "goal": "Refuse a natural-language request after interpretation when the target host is outside policy.",
  "requires_guest_openai": true,
  "input_mode": "text_line",
  "input_payload": "Summarize http://10.0.2.99:8082/source in three bullet points.",
  "fixture": {
    "source_asset": "source.md"
  },
  "expect": {
    "boot_prompt": "Goal >",
    "timeout_sec": 90,
    "required_trace_events": [
      "goal_received",
      "goal_text_received",
      "agent_loop_started",
      "model_interpretation_started",
      "model_interpretation_result",
      "intent_compiled",
      "plan_created",
      "policy_checked",
      "goal_refused"
    ],
    "result_required": false,
    "terminal_result_required": true,
    "terminal_fields": [
      "status",
      "reason"
    ],
    "intent_fields": [
      "interaction_kind",
      "action",
      "source_url",
      "max_items",
      "output_language",
      "style",
      "requires_clarification"
    ],
    "expected_intent": {
      "interaction_kind": "task",
      "action": "local_summary",
      "source_url": "http://10.0.2.99:8082/source",
      "max_items": 3,
      "output_language": "default",
      "style": "bullet",
      "requires_clarification": false
    },
    "terminal_status": "refused",
    "terminal_reason_required": true,
    "request_counts": {
      "source_requests": 0,
      "interpretation_requests": 0,
      "model_requests": 0
    }
  }
}
