{
  "goal_id": "m6-search-then-followup",
  "goal": "Exercise multi-turn research behavior with known-source reuse.",
  "turns": [
    {
      "input_mode": "text_line",
      "input_payload": "Search the web for m6 performance update and summarize what happened."
    },
    {
      "input_mode": "text_line",
      "input_payload": "Summarize only the performance claims."
    }
  ],
  "fixture": {
    "source_asset": "source.md",
    "source_pages_asset": "pages.json",
    "search_asset": "search.json"
  },
  "expect": {
    "boot_prompt": "Goal >",
    "timeout_sec": 45,
    "required_trace_events": [
      "session_started",
      "user_turn_received",
      "model_turn_started",
      "assistant_response_rendered",
      "loop_stopped"
    ],
    "session_transcript_required": true,
    "expected_turn_count": 2,
    "result_required": false,
    "terminal_result_required": true,
    "terminal_fields": [
      "status",
      "summary"
    ],
    "terminal_status": "ok",
    "terminal_summary_must_include": [
      "fixture path stays deterministic",
      "Brave Search"
    ],
    "expected_tool_calls": [
      {
        "event": "tool_call_requested",
        "tool": "search_web"
      },
      {
        "event": "tool_call_requested",
        "tool": "fetch_url"
      }
    ],
    "max_tool_calls": 2,
    "search_results_required": true,
    "search_count": 1,
    "fetched_source_count": 1,
    "source_memory_required": true,
    "source_memory_count": 1,
    "request_counts": {
      "source_requests": 1
    }
  }
}
