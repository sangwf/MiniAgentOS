{
  "goal_id": "m4-loop-tools-meta",
  "goal": "Exercise a normal M4 fetch turn followed by a local tools/capabilities question.",
  "requires_guest_openai": true,
  "turns": [
    {
      "input_mode": "text_line",
      "input_payload": "Read {{SOURCE_URL}} and summarize it in one sentence."
    },
    {
      "input_mode": "text_line",
      "input_payload": "你都有什么工具可被调用？"
    }
  ],
  "fixture": {
    "source_asset": "source.md"
  },
  "expect": {
    "boot_prompt": "Goal >",
    "timeout_sec": 120,
    "required_trace_events": [
      "session_started",
      "user_turn_received",
      "assistant_response_rendered",
      "loop_stopped",
      "goal_completed"
    ],
    "session_transcript_required": true,
    "expected_turn_count": 2,
    "max_tool_calls": 2,
    "expected_tool_calls": [
      {
        "event": "tool_call_requested",
        "tool": "fetch_url"
      }
    ],
    "result_required": false,
    "terminal_result_required": true,
    "terminal_fields": [
      "status",
      "summary"
    ],
    "terminal_status": "ok",
    "terminal_summary_must_include": [
      "fetch_url",
      "post_tweet",
      "read_session_state"
    ],
    "request_counts": {
      "source_requests": 1,
      "interpretation_requests": 0,
      "model_requests": 0,
      "x_post_requests": 0,
      "x_search_requests": 0,
      "x_user_posts_requests": 0
    }
  }
}
